# =============================================================================
# .env.example  –  Environment Variables Template
# =============================================================================
# Copy this file to ".env" and fill in the values for local development.
#   cp .env.example .env
#
# IMPORTANT: Never commit your real .env file to Git. Add ".env" to .gitignore.
# On Railway, you set these variables in the Railway dashboard (not in a file).
# =============================================================================

# PostgreSQL connection string — copy this from Railway:
#   Railway dashboard → PostgreSQL service → Connect tab → "Public Network" URL
# It will look something like this:
# DATABASE_URL=postgresql://postgres:AbCdEf123@monorail.proxy.rlwy.net:12345/railway
DATABASE_URL=postgresql://postgres:lJNUNpvbCaWqGRtjHcIcchZYiNjesyfM@crossover.proxy.rlwy.net:38311/railway

# Set to "production" when deployed; leave blank or set to "development" locally
NODE_ENV=production

# Port the server listens on (Railway sets this automatically; 3000 is fine locally)
PORT=3000

# Secret key that external systems must send to use the /api/log endpoint.
# Use any long random string — the longer the better.
# Example: openssl rand -hex 32   (run this in a terminal to generate one)
# On Railway: add this in your service's Variables panel.
API_KEY=replace-this-with-a-long-random-secret
